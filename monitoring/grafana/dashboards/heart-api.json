{
  "title": "Heart API Dashboard",
  "uid": "heart-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Total Requests",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"expr": "sum(http_requests_total)", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "id": 2,
      "gridPos": {"x": 6, "y": 0, "w": 18, "h": 8},
      "targets": [
        {"expr": "sum by (handler) (rate(http_requests_total[1m]))", "refId": "A", "legendFormat": "{{handler}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 (s)",
      "id": 3,
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket[5m])))", "refId": "A", "legendFormat": "{{handler}}"}
      ]
    }
  ]
}
